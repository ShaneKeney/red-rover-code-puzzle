{
  "name": "red-rover-code-puzzle",
  "version": "1.0.0",
  "description": "Simple Node starter",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "prestart": "npm run build",
    "dev": "tsx src/index.ts",
    "dev:watch": "tsx watch src/index.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "private": true,
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
